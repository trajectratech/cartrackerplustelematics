---
import type { SeoLandingPage, ThemeConfig } from "../types/theme";
import mainJson from "../data/car-tracker-plus-telematics.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLandingPageSeo } from "../utils/seo";
import TrackingCarIllustration from "../components/TrackingCarIllustration.astro";

const data = mainJson as ThemeConfig;

export function getStaticPaths() {
	const theme = mainJson as ThemeConfig;
	return (theme.seo?.landingPages ?? []).map((page) => ({
		params: { slug: page.slug },
		props: { page },
	}));
}

type Props = {
	page: SeoLandingPage;
};

const { page } = Astro.props as Props;
const seo = getLandingPageSeo(data, page);
const relatedPages = (data.seo?.landingPages ?? [])
	.filter((item) => item.slug !== page.slug)
	.slice(0, 3);
const serviceAreas = data.seo?.serviceAreas?.length ? data.seo.serviceAreas : ["Nigeria"];
const secondaryKeywords = page.secondaryKeywords ?? [];

const colorVars = {
	"--color-primary": data.colors.primary,
	"--color-secondary": data.colors.secondary,
	"--color-accent": data.colors.accent,
	"--color-background": data.colors.background,
	"--color-text": data.colors.text,
	"--color-heading": data.colors.heading,
	"--color-link": data.colors.link,
	"--color-hover": data.colors.hover,
	"--color-active": data.colors.active,
	"--color-error": data.colors.error,
	"--color-success": data.colors.success,
	"--color-muted": data.colors.muted,
};
---

<BaseLayout
	data={data}
	layout={[]}
	colorVars={colorVars}
	metadata={seo.metadata}
	structuredData={seo.structuredData}
	sameAsUrls={seo.sameAsUrls}
>
	<section class="scrolling-section relative isolate overflow-hidden bg-[var(--color-secondary)] px-6 py-16 text-white md:py-24">
		<div
			class="absolute inset-0"
			style="background:
				radial-gradient(circle at top left, rgba(181, 18, 27, 0.34), transparent 34%),
				radial-gradient(circle at center right, rgba(255, 255, 255, 0.08), transparent 28%),
				linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0));"
			aria-hidden="true"
		/>
		<div
			class="absolute inset-0 opacity-60"
			style="background-image:
				linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
				linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
				background-size: 60px 60px;"
			aria-hidden="true"
		/>
		<div class="relative mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-center">
			<div class="max-w-3xl">
				<p class="inline-flex rounded-full border border-[color:rgba(255,255,255,0.12)] bg-[color:rgba(255,255,255,0.06)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-[color:rgba(255,255,255,0.72)]">
					{page.primaryKeyword}
				</p>
				<h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
					{page.headline}
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-8 text-[color:rgba(255,255,255,0.76)]">
					{page.intro}
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a
						href={data.content.heroSection.ctaUrl}
						target="_blank"
						rel="noopener noreferrer"
						data-button
						style="background-color: var(--color-primary); color: white !important; -webkit-text-fill-color: white; text-decoration: none;"
						class="cursor-pointer rounded-full px-6 py-3 font-semibold shadow-[0_18px_40px_rgba(181,18,27,0.26)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_24px_46px_rgba(181,18,27,0.30)]"
					>
						{data.content.heroSection.ctaText}
					</a>
					<a
						href="/#services"
						class="inline-flex items-center justify-center rounded-full border border-[color:rgba(255,255,255,0.14)] px-6 py-3 text-sm font-semibold tracking-[0.02em] text-white transition hover:border-[color:var(--color-primary)] hover:text-[color:var(--color-accent)]"
					>
						View Services
					</a>
				</div>
				<div class="mt-10 flex flex-wrap gap-3">
					{secondaryKeywords.slice(0, 3).map((keyword) => (
						<span class="rounded-full border border-[color:rgba(255,255,255,0.10)] bg-[color:rgba(255,255,255,0.04)] px-4 py-2 text-sm text-[color:rgba(255,255,255,0.72)]">
							{keyword}
						</span>
					))}
				</div>
			</div>

			<div class="card rounded-[2rem] border border-[color:rgba(255,255,255,0.10)] bg-[linear-gradient(180deg,rgba(181,18,27,0.14),rgba(255,255,255,0.03))] p-5 shadow-[0_22px_60px_rgba(0,0,0,0.22)]">
				<div class="grid gap-5 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
					<div class="h-[240px] sm:h-[300px]">
						<TrackingCarIllustration />
					</div>
					<div class="space-y-4">
						<div class="rounded-2xl border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] px-4 py-4">
							<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-accent)]">
								Security Snapshot
							</p>
							<p class="mt-2 text-sm leading-7 text-[color:rgba(255,255,255,0.80)]">
								{page.serviceType} for {page.location} with professional installation standards, clear monitoring, and faster response intent.
							</p>
						</div>
						<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
							<div class="rounded-2xl border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] px-4 py-4">
								<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[color:rgba(255,255,255,0.52)]">
									Coverage
								</p>
								<p class="mt-2 text-base font-semibold text-white">{page.location}</p>
							</div>
							<div class="rounded-2xl border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] px-4 py-4">
								<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[color:rgba(255,255,255,0.52)]">
									Support
								</p>
								<p class="mt-2 text-base font-semibold text-white">Security-led support</p>
							</div>
							<div class="rounded-2xl border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] px-4 py-4 sm:col-span-2 lg:col-span-1">
								<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[color:rgba(255,255,255,0.52)]">
									Search Match
								</p>
								<p class="mt-2 text-base font-semibold text-white">{page.primaryKeyword}</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="scrolling-section bg-[var(--color-background)] px-6 py-20 md:py-24">
		<div class="mx-auto max-w-7xl">
			<div class="mb-10 max-w-3xl">
				<p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--color-primary)]">
					Key Benefits
				</p>
				<h2 class="mt-4 text-4xl font-extrabold tracking-tight text-[var(--color-heading)]">
					What this setup helps you do with more confidence.
				</h2>
			</div>
			<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3" role="list">
				{page.benefits.map((benefit, index) => (
					<article
						class="card rounded-[1.75rem] border p-6"
						style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);"
					>
						<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">
							Benefit 0{index + 1}
						</p>
						<h3 class="mt-3 text-lg font-bold text-[var(--color-heading)]">{benefit}</h3>
						<p class="mt-3 text-sm leading-7" style="color: var(--text-soft);">
							{data.brand.businessName} supports this use case with disciplined installation, monitoring visibility, and dependable support after deployment.
						</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="scrolling-section bg-[var(--color-background)] px-6 py-20 md:py-24">
		<div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
			<div class="rounded-[2rem] border p-8" style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);">
				<p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--color-primary)]">
					Ideal For
				</p>
				<h2 class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-heading)]">
					A stronger fit for buyers comparing security quality, not just device price.
				</h2>
				<p class="mt-5 text-base leading-8" style="color: var(--text-soft);">
					This page is for buyers who want to confirm local coverage, understand what protection layer suits them, and move faster with a provider that can install and support the setup properly.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<span class="rounded-full px-4 py-2 text-sm font-medium text-[var(--color-primary)]" style="background: var(--surface-3);">
						{page.primaryKeyword}
					</span>
					{secondaryKeywords.map((keyword) => (
						<span class="rounded-full border px-4 py-2 text-sm text-[var(--color-text)]" style="border-color: var(--border-soft);">
							{keyword}
						</span>
					))}
				</div>
			</div>

			<aside class="rounded-[2rem] border border-[color:rgba(181,18,27,0.32)] bg-[linear-gradient(180deg,rgba(181,18,27,0.24),rgba(255,255,255,0.03))] p-8 text-white shadow-[var(--shadow-strong)]" style="background-color: var(--color-secondary);">
				<p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--color-accent)]">
					Contact Desk
				</p>
				<h2 class="mt-4 text-3xl font-bold">Speak with {data.brand.businessName}</h2>
				<ul class="mt-6 space-y-4 text-sm leading-7 text-[color:rgba(255,255,255,0.78)]">
					<li>{data.contact.phone}</li>
					<li>{data.contact.email}</li>
					<li>{data.contact.address}</li>
					<li>Coverage: {serviceAreas.join(", ")}</li>
				</ul>
				<a
					href={data.content.heroSection.ctaUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="mt-8 inline-flex items-center justify-center rounded-full bg-[var(--color-accent)] px-6 py-3 text-sm font-semibold text-[var(--color-heading)] transition hover:brightness-105"
				>
					Start An Enquiry
				</a>
			</aside>
		</div>
	</section>

	{page.faqs?.length ? (
		<section class="scrolling-section bg-[var(--color-background)] px-6 py-20 md:py-24">
			<div class="mx-auto max-w-5xl">
				<div class="max-w-2xl">
					<p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--color-primary)]">
						Questions
					</p>
					<h2 class="mt-4 text-4xl font-extrabold tracking-tight text-[var(--color-heading)]">
						{page.serviceType} FAQs
					</h2>
				</div>
				<div class="mt-10 grid gap-5">
					{page.faqs.map((faq) => (
						<article class="card rounded-[1.75rem] border p-6" style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);">
							<h3 class="text-lg font-semibold text-[var(--color-heading)]">
								{faq.question}
							</h3>
							<p class="mt-3 leading-8" style="color: var(--text-soft);">
								{faq.answer}
							</p>
						</article>
					))}
				</div>
			</div>
		</section>
	) : null}

	{relatedPages.length ? (
		<section class="scrolling-section bg-[var(--color-background)] px-6 py-20 md:py-24">
			<div class="mx-auto max-w-7xl">
				<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
					<div class="max-w-2xl">
						<p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--color-primary)]">
							Related Searches
						</p>
						<h2 class="mt-4 text-4xl font-extrabold tracking-tight text-[var(--color-heading)]">
							Explore other search-led pages.
						</h2>
					</div>
					<a href="/#services" class="text-sm font-semibold text-[var(--color-primary)]">
						Back to homepage services
					</a>
				</div>
				<div class="mt-10 grid gap-6 lg:grid-cols-3">
					{relatedPages.map((item) => (
						<a
							href={`/${item.slug}/`}
							class="card rounded-[1.75rem] border p-7 transition duration-300 hover:-translate-y-1"
							style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);"
						>
							<p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">
								{item.primaryKeyword}
							</p>
							<h3 class="mt-4 text-2xl font-bold text-[var(--color-heading)]">
								{item.pageTitle}
							</h3>
							<p class="mt-4 text-sm leading-7" style="color: var(--text-soft);">
								{item.metaDescription}
							</p>
						</a>
					))}
				</div>
			</div>
		</section>
	) : null}
</BaseLayout>
