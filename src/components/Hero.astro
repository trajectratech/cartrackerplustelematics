---
import type { ThemeConfig } from "../types/theme";
import CallToActionButton from "./CallToActionButton.astro";
import TrackingCarIllustration from "./TrackingCarIllustration.astro";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const content = data.content.heroSection;
const trustStats = data.content.trustSection?.stats?.slice(0, 3) ?? [];
---

{
	content && (
		<section
			class="hero scrolling-section relative isolate overflow-hidden bg-[var(--color-secondary)] px-6 py-10 text-white sm:py-16"
			aria-label="Hero Section"
		>
			<div
				class="absolute inset-0 opacity-100"
				style="background:
					radial-gradient(circle at top left, rgba(15, 76, 129, 0.35), transparent 36%),
					radial-gradient(circle at bottom right, rgba(201, 164, 92, 0.18), transparent 32%),
					linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));"
				aria-hidden="true"
			/>
			<div class="relative z-10 mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)] lg:items-center">
				<div class="max-w-3xl">
					<p class="inline-flex rounded-full border border-[color:rgba(255,255,255,0.12)] bg-[color:rgba(255,255,255,0.06)] px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] text-[color:rgba(255,255,255,0.78)]">
						{data.brand.tagline}
					</p>
					<h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
						{content.heading}
					</h1>
					<p class="mt-6 max-w-2xl text-base leading-8 text-[color:rgba(255,255,255,0.78)] sm:text-lg">
						{content.paragraph}
					</p>
					<div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
						<CallToActionButton href={content.ctaUrl} label={content.ctaText} />
						<a
							href="#services"
							class="inline-flex items-center justify-center rounded-full border border-[color:rgba(255,255,255,0.16)] px-6 py-3 text-sm font-semibold tracking-[0.02em] text-white transition hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
						>
							Explore Services
						</a>
					</div>
					{
						trustStats.length > 0 && (
							<div class="mt-10 grid gap-4 sm:grid-cols-3">
								{trustStats.map((stat) => (
									<div class="rounded-3xl border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] px-5 py-5">
										<p class="text-2xl font-bold text-white">{stat.value}</p>
										<p class="mt-1 text-sm text-[color:rgba(255,255,255,0.68)]">{stat.label}</p>
									</div>
								))}
							</div>
						)
					}
				</div>
				<div class="grid gap-5">
					<div class="rounded-[2rem] border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] p-6 shadow-[0_30px_80px_rgba(0,0,0,0.24)]">
						<p class="text-sm font-semibold uppercase tracking-[0.22em] text-[color:var(--color-accent)]">
							Deployment Focus
						</p>
						<h2 class="mt-4 text-2xl font-bold text-white">
							Private vehicles, executive mobility, and fleet operations.
						</h2>
						<p class="mt-3 text-sm leading-7 text-[color:rgba(255,255,255,0.72)]">
							Choose a cleaner rollout path with tracking, telematics, and security add-ons delivered with a disciplined installation process.
						</p>
						<div class="mt-6 grid gap-3 text-sm text-[color:rgba(255,255,255,0.76)]">
							<div class="rounded-2xl bg-[color:rgba(255,255,255,0.04)] px-4 py-3">Email: {data.contact.email}</div>
							<div class="rounded-2xl bg-[color:rgba(255,255,255,0.04)] px-4 py-3">Call: {data.contact.phone}</div>
							<div class="rounded-2xl bg-[color:rgba(255,255,255,0.04)] px-4 py-3">Base: {data.contact.address}</div>
						</div>
					</div>
					<div class="rounded-[2rem] border border-[color:rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03))] p-4">
						<div class="h-[250px] sm:h-[320px]">
							<TrackingCarIllustration />
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}
