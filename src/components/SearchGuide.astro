---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const searchGuide = Astro.props.data.content.searchGuideSection;
const landingPages = Astro.props.data.seo?.landingPages ?? [];
const items =
	landingPages.length > 0
		? landingPages.map((page) => ({
				title: page.headline,
				description: page.metaDescription,
				href: `/${page.slug}/`,
				keyword: page.primaryKeyword,
			}))
		: (searchGuide?.items ?? []);
const heading =
	searchGuide?.heading ?? "Search guide for the services people look for most.";
const paragraph =
	searchGuide?.paragraph ??
	"Explore focused pages built around the search terms clients already use when they need a car tracker, fleet telematics, or dash camera solution in Nigeria.";
---

{
	items.length ? (
		<section
			id="search-guide"
			aria-labelledby="search-guide-heading"
			class="scrolling-section bg-white px-6 py-24"
		>
			<div class="mx-auto max-w-7xl">
				<div class="mx-auto max-w-3xl text-center">
					<p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-primary)]">
						Search Guide
					</p>
					<h2
						id="search-guide-heading"
						class="mt-4 text-4xl font-extrabold tracking-tight text-[var(--color-heading)] sm:text-5xl"
					>
						{heading}
					</h2>
					{
						paragraph && (
							<p class="mt-5 text-base leading-8 text-[var(--color-muted)] sm:text-lg">
								{paragraph}
							</p>
						)
					}
				</div>

				<div class="mt-14 grid gap-6 lg:grid-cols-2">
					{items.map((item, index) => (
						<a
							href={item.href}
							class="card group rounded-[2rem] border border-[color:rgba(8,17,31,0.08)] bg-[var(--color-background)] p-7 shadow-[0_20px_50px_rgba(8,17,31,0.06)] transition duration-300 hover:-translate-y-1 hover:border-[color:rgba(15,76,129,0.24)] hover:shadow-[0_24px_60px_rgba(8,17,31,0.10)]"
						>
							<div class="flex items-start justify-between gap-4">
								<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[color:rgba(15,76,129,0.10)] text-[var(--color-primary)]">
									<Icon name="heroicons-outline:magnifying-glass" class="h-7 w-7" />
								</div>
								<span class="text-sm font-semibold text-[color:rgba(8,17,31,0.36)]">
									0{index + 1}
								</span>
							</div>
							{
								item.keyword && (
									<p class="mt-6 text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">
										{item.keyword}
									</p>
								)
							}
							<h3 class="mt-3 text-2xl font-bold text-[var(--color-heading)]">
								{item.title}
							</h3>
							<p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">
								{item.description}
							</p>
							<div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-primary)]">
								<span>Open page</span>
								<Icon name="heroicons-outline:arrow-right" class="h-5 w-5 transition group-hover:translate-x-1" />
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	) : null
}
