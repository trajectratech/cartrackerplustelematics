---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { servicesSection } = Astro.props.data.content;
---

{Array.isArray(servicesSection?.listItems) && servicesSection?.listItems?.length > 0 && <section
	id="services"
	aria-labelledby="services-heading"
	class="scrolling-section relative overflow-hidden bg-[var(--color-background)] py-24 text-[var(--color-text)]"
>
	<div
		class="absolute inset-0 opacity-100"
		style="background:
			radial-gradient(circle at top right, rgba(181, 18, 27, 0.10), transparent 32%),
			linear-gradient(180deg, rgba(181, 18, 27, 0.02), rgba(255, 255, 255, 0));"
		aria-hidden="true"
	/>
	<div class="relative z-10 mx-auto max-w-7xl px-6">
		<div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-end">
			<div class="max-w-2xl">
				<p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-primary)]">
					What We Protect
				</p>
				<h2
					id="services-heading"
					class="mt-4 text-4xl font-extrabold leading-tight text-[var(--color-heading)] sm:text-5xl"
				>
					{servicesSection.heading}
				</h2>
			</div>
			<div class="rounded-[2rem] border px-6 py-6" style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);">
				<p class="text-sm leading-8 sm:text-base" style="color: var(--text-soft);">
					{servicesSection.paragraph}
				</p>
				<p class="mt-3 text-sm font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">
					Protection is matched to value, usage, and response risk.
				</p>
			</div>
		</div>
		<div class="mt-14 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
			{
				servicesSection?.listItems.map((service, index) => {
					const serviceId = `service-title-${index}`;
					return (
						<article
							aria-labelledby={serviceId}
							class="card group rounded-[2rem] border p-7 transition duration-300 hover:-translate-y-1"
							style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);"
						>
							<div class="flex items-center justify-between gap-4">
								<div
									class="flex h-14 w-14 items-center justify-center rounded-2xl text-[var(--color-primary)]"
									style="background: var(--surface-3);"
									role="img"
									aria-hidden="true"
								>
									<Icon name="heroicons-outline:check-circle" class="h-7 w-7" />
								</div>
								<span class="text-sm font-semibold" style="color: var(--text-faint);">
									0{index + 1}
								</span>
							</div>
							<h3
								id={serviceId}
								class="mt-6 text-xl font-semibold text-[var(--color-heading)]"
							>
								{service.title}
							</h3>
							{service.description && (
								<p class="mt-3 text-sm leading-7" style="color: var(--text-soft);">
									{service.description}
								</p>
							)}
						</article>
					);
				})
			}
		</div>
	</div>
</section>
}
