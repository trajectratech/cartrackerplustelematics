---
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const trust = Astro.props.data?.content?.trustSection;
---

{
	trust?.heading && (
		<section class="scrolling-section bg-[var(--color-background)] px-4 py-20 text-[var(--color-heading)]">
			<div class="mx-auto grid max-w-7xl gap-10 px-2 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
				<div class="rounded-[2rem] px-8 py-10 text-white" style="background: var(--color-secondary); box-shadow: var(--shadow-strong);">
					<p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-accent)]">
						The Reality
					</p>
					<h2 class="mt-4 text-3xl font-bold leading-tight md:text-4xl">
						{trust.heading}
					</h2>
					<p class="mt-5 text-base leading-8 text-[color:rgba(255,255,255,0.72)]">
						A vehicle can be gone before the first phone call is even finished. Good protection starts with seeing movement early, getting alerts fast, and having a response path that is more useful than guesswork.
					</p>
					{Array.isArray(trust.guarantees) && trust.guarantees.length > 0 && (
						<div class="mt-8 grid gap-3">
							{trust.guarantees.map((g) => (
								<div class="rounded-2xl border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(181,18,27,0.14)] px-4 py-4 text-sm text-[color:rgba(255,255,255,0.82)]">
									{g}
								</div>
							))}
						</div>
					)}
				</div>

				<div class="grid gap-5 sm:grid-cols-2">
					<div class="rounded-[2rem] border px-6 py-7 sm:col-span-2" style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);">
						<p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">
							What This Solves
						</p>
						<div class="mt-5 grid gap-3 text-sm md:grid-cols-3" style="color: var(--text-soft);">
							<div class="rounded-2xl px-4 py-4" style="background: var(--surface-2);">Delayed theft response</div>
							<div class="rounded-2xl px-4 py-4" style="background: var(--surface-2);">Poor visibility across vehicles</div>
							<div class="rounded-2xl px-4 py-4" style="background: var(--surface-2);">Weak after-installation support</div>
						</div>
					</div>
					{Array.isArray(trust.stats) && trust.stats.length > 0 && trust.stats.map((stat) => (
						<div class="rounded-[2rem] border px-6 py-7" style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);">
							<p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">
								{stat.label}
							</p>
							<p class="mt-4 text-3xl font-extrabold text-[var(--color-heading)] md:text-4xl" data-countup={stat.value}>
								{stat.value}
							</p>
						</div>
					))}
				</div>
			</div>
		</section>
	)
}
