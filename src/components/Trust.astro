---
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const trust = Astro.props.data?.content?.trustSection;
---

{
	trust?.heading && (
		<section class="scrolling-section bg-white px-4 py-20 text-[var(--color-heading)]">
			<div class="mx-auto grid max-w-7xl gap-10 px-2 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
				<div class="rounded-[2rem] bg-[var(--color-secondary)] px-8 py-10 text-white">
					<p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-accent)]">
						Why It Feels Different
					</p>
					<h2 class="mt-4 text-3xl font-bold leading-tight md:text-4xl">
						{trust.heading}
					</h2>
					<p class="mt-5 text-base leading-8 text-[color:rgba(255,255,255,0.72)]">
						We focus on clean deployments, dependable visibility, and support that helps owners and operators act quickly when something matters.
					</p>
					{Array.isArray(trust.guarantees) && trust.guarantees.length > 0 && (
						<div class="mt-8 grid gap-3">
							{trust.guarantees.map((g) => (
								<div class="rounded-2xl border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] px-4 py-4 text-sm text-[color:rgba(255,255,255,0.82)]">
									{g}
								</div>
							))}
						</div>
					)}
				</div>

				<div class="grid gap-5 sm:grid-cols-2">
					{Array.isArray(trust.stats) && trust.stats.length > 0 && trust.stats.map((stat) => (
						<div class="rounded-[2rem] border border-[color:rgba(8,17,31,0.08)] bg-[var(--color-background)] px-6 py-7 shadow-[0_18px_48px_rgba(8,17,31,0.06)]">
							<p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--color-primary)]">
								{stat.label}
							</p>
							<p class="mt-4 text-3xl font-extrabold text-[var(--color-heading)] md:text-4xl">
								{stat.value}
							</p>
						</div>
					))}
				</div>
			</div>
		</section>
	)
}
