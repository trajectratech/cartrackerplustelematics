---
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { heading, faqs } = Astro.props.data.content.faqsSection;
---

{
	faqs && Array.isArray(faqs) && faqs.length > 0 && (
		<section id="faqs" class="faqs-section scrolling-section bg-[var(--color-background)] px-4 py-24">
			<div class="mx-auto max-w-4xl">
			<p class="text-center text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-primary)]">
				Answers
			</p>
			<h2 class="mt-4 text-center text-3xl font-bold text-[var(--color-heading)] md:text-4xl">
				{heading}
			</h2>

			<div class="mt-12 space-y-4">
				{faqs.map((faq) => (
					<details class="card group rounded-[1.75rem] border shadow-[var(--shadow-soft)] transition-all duration-300 open:border-[color:var(--border-strong)]" style="border-color: var(--border-soft); background: var(--card-bg-elevated);">
						<summary class="flex cursor-pointer items-center justify-between gap-6 px-6 py-5 font-semibold text-[var(--color-heading)]">
							<span>{faq.question}</span>
							<span class="text-[var(--color-primary)] transition-transform duration-300 group-open:rotate-180">
								⌃
							</span>
						</summary>
						<div class="px-6 pb-5 text-sm leading-7" style="color: var(--text-soft);">
							{faq.answer}
						</div>
					</details>
				))}
			</div>
			</div>
		</section>
	)
}

<style>
	.faqs-section details summary::-webkit-details-marker {
		display: none;
	}
</style>
