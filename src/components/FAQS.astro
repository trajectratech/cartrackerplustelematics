---
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { heading, faqs } = Astro.props.data.content.faqsSection;
---

{
	faqs && Array.isArray(faqs) && faqs.length > 0 && (
		<section id="faqs" class="faqs-section scrolling-section bg-white px-4 py-24">
			<div class="mx-auto max-w-4xl">
			<h2 class="text-center text-3xl font-bold text-[var(--color-heading)] md:text-4xl">
				{heading}
			</h2>

			<div class="mt-12 space-y-4">
				{faqs.map((faq, index) => (
					<details class="card group rounded-[1.75rem] border border-[color:rgba(8,17,31,0.08)] bg-[var(--color-background)] shadow-[0_14px_32px_rgba(8,17,31,0.04)] transition-all duration-300 open:border-[color:rgba(15,76,129,0.30)] open:bg-white">
						<summary class="flex cursor-pointer items-center justify-between gap-6 px-6 py-5 font-semibold text-[var(--color-heading)]">
							<span>{faq.question}</span>
							<span class="text-[var(--color-primary)] transition-transform duration-300 group-open:rotate-180">
								⌃
							</span>
						</summary>
						<div class="px-6 pb-5 text-sm leading-7 text-[var(--color-muted)]">
							{faq.answer}
						</div>
					</details>
				))}
			</div>
			</div>
		</section>
	)
}

<style>
	.faqs-section details summary::-webkit-details-marker {
		display: none;
	}
</style>
