---
// HowItWorks.astro
import type { ThemeConfig } from "../types/theme";

import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
}

const howItWorksSection = Astro.props.data.content.howItWorksSection;
const shouldRenderSection = Boolean(
	howItWorksSection &&
		((Array.isArray(howItWorksSection.steps) &&
			howItWorksSection.steps.length > 0) ||
			howItWorksSection.url),
);
---

{
	(
		<div>
			{shouldRenderSection && (
				<section
					id="how-it-works"
					class="scrolling-section bg-[var(--color-background)] py-24 text-[var(--color-text)]"
				>
					{howItWorksSection && (
						<div class="mx-auto max-w-7xl px-6">
							<div class="mx-auto max-w-3xl text-center">
								<p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-primary)]">
									How It Works
								</p>
								{howItWorksSection?.heading && (
									<h2 class="mt-4 text-center text-3xl font-bold text-[var(--color-heading)] md:text-4xl">
										{howItWorksSection.heading}
									</h2>
								)}
								<p class="mt-5 text-base leading-8" style="color: var(--text-soft);">
									Every fitting starts with the vehicle, the level of risk, and the fastest path to giving you live control.
								</p>
							</div>

							<div class="mt-14 grid gap-6 md:grid-cols-3">
								{Array.isArray(howItWorksSection?.steps) &&
									howItWorksSection?.steps.length > 0 &&
									howItWorksSection?.steps.map((step, index) => (
										<div class="card rounded-[2rem] border p-7" style="border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);">
											<div class="flex h-14 w-14 items-center justify-center rounded-2xl text-lg font-bold text-[var(--color-primary)]" style="background: var(--surface-3);">
												0{index + 1}
											</div>
											{step.iconUrl && (
												<div class="mx-auto mb-4 h-14 w-14">
													<img
														src={step.iconUrl}
														alt={step.title}
														class="w-full h-full object-contain"
													/>
												</div>
											)}
											<h3 class="mt-6 text-xl font-semibold text-[var(--color-heading)]">
												{step.title}
											</h3>
											<p class="mt-3 text-sm leading-7" style="color: var(--text-soft);">
												{step.description}
											</p>
										</div>
									))}
							</div>

							{howItWorksSection?.url && howItWorksSection?.urlText && (
								<div class="mt-10 text-center" title={howItWorksSection?.urlText}>
									<CallToActionButton
										href={howItWorksSection?.url}
										label={howItWorksSection?.urlText}
									/>
								</div>
							)}
						</div>
					)}
				</section>
			)}
		</div>
	)
}
