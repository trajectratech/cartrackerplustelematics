---
// HowItWorks.astro
import type { ThemeConfig } from "../types/theme";

import CallToActionButton from "./CallToActionButton.astro";

export interface Props {
	data: ThemeConfig;
}

const howItWorksSection = Astro.props.data.content.howItWorksSection;
const shouldRenderSection = Boolean(
	howItWorksSection &&
		((Array.isArray(howItWorksSection.steps) &&
			howItWorksSection.steps.length > 0) ||
			howItWorksSection.url),
);
---

{
	(
		<div>
			{shouldRenderSection && (
				<section
					id="how-it-works"
					class="scrolling-section bg-white py-24 text-[var(--color-text)]"
				>
					{howItWorksSection && (
						<div class="mx-auto max-w-7xl px-6">
							{howItWorksSection?.heading && (
								<h2 class="text-center text-3xl font-bold text-[var(--color-heading)] md:text-4xl">
									{howItWorksSection.heading}
								</h2>
							)}

							<div class="mt-14 grid gap-6 md:grid-cols-3">
								{Array.isArray(howItWorksSection?.steps) &&
									howItWorksSection?.steps.length > 0 &&
									howItWorksSection?.steps.map((step, index) => (
										<div class="card rounded-[2rem] border border-[color:rgba(8,17,31,0.08)] bg-[var(--color-background)] p-7 shadow-[0_20px_50px_rgba(8,17,31,0.06)]">
											<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[color:rgba(15,76,129,0.10)] text-lg font-bold text-[var(--color-primary)]">
												0{index + 1}
											</div>
											{step.iconUrl && (
												<div class="mx-auto mb-4 h-14 w-14">
													<img
														src={step.iconUrl}
														alt={step.title}
														class="w-full h-full object-contain"
													/>
												</div>
											)}
											<h3 class="mt-6 text-xl font-semibold text-[var(--color-heading)]">
												{step.title}
											</h3>
											<p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">
												{step.description}
											</p>
										</div>
									))}
							</div>

							{howItWorksSection?.url && howItWorksSection?.urlText && (
								<div class="mt-10 text-center" title={howItWorksSection?.urlText}>
									<CallToActionButton
										href={howItWorksSection?.url}
										label={howItWorksSection?.urlText}
									/>
								</div>
							)}
						</div>
					)}
				</section>
			)}
		</div>
	)
}
