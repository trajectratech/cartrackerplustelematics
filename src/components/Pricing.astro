---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
---

{
	Array.isArray(data?.pricing) && data.pricing.length > 0 && (
		<section
			id="pricing"
			aria-labelledby="pricing-heading"
			class="scrolling-section bg-[var(--color-secondary)] py-24 text-white"
		>
			<div class="mx-auto max-w-7xl px-6">
				<p class="text-center text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-accent)]">
					Packages
				</p>
				<h2
					id="pricing-heading"
					class="mt-4 text-center text-4xl font-extrabold text-white"
				>
					Choose a package that fits your level of visibility and protection.
				</h2>
				<p class="mx-auto mt-5 max-w-3xl text-center text-base leading-8 text-[color:rgba(255,255,255,0.72)]">
					Final recommendations depend on vehicle type, deployment size, and preferred add-ons. We guide you to the right package before installation.
				</p>

				<div class="mt-14 grid gap-6 xl:grid-cols-4" role="list">
					{data.pricing.map((plan, idx) => (
						<article
							role="listitem"
							class="card rounded-[2rem] border border-[color:rgba(255,255,255,0.10)] bg-[color:rgba(255,255,255,0.04)] p-7 text-white transition hover:-translate-y-1 hover:border-[color:rgba(201,164,92,0.55)]"
							style={{
								animationDelay: `${idx * 100}ms`,
								animationFillMode: "both",
							}}
							aria-label={`Pricing plan: ${plan.plan}`}
						>
							<header>
								<p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:rgba(255,255,255,0.56)]">
									Package 0{idx + 1}
								</p>
								<h3 class="mt-4 text-2xl font-bold text-white">
									{plan.plan}
								</h3>

								<p class="mt-4 text-sm leading-7 text-[color:rgba(255,255,255,0.70)]">
									Tailored quote after vehicle review and installation scope confirmation.
								</p>
							</header>

							<ul class="mt-8 space-y-3 text-sm text-[color:rgba(255,255,255,0.82)]">
								{plan.features.map((f) => (
									<li class="flex items-start gap-3">
										<Icon
											name="heroicons-solid:check"
											class="mt-0.5 h-5 w-5 text-[var(--color-accent)]"
											aria-hidden="true"
										/>
										<span>{f}</span>
									</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</div>
		</section>
	)
}
