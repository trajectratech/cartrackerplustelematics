---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const featuredPlanIndex = 1;
const planMeta = [
	{
		eyebrow: "ESSENTIAL",
		audience: "Standard vehicles and everyday private drivers",
		priceLabel: "Protection band",
		summary: "Matched after vehicle review",
		supportLabel: "Core tracking and alert coverage",
	},
	{
		eyebrow: "RECOMMENDED",
		audience: "Higher-value vehicles that need stronger response options",
		priceLabel: "Priority band",
		summary: "Most requested setup",
		supportLabel: "Remote response and priority after-sales support",
	},
	{
		eyebrow: "FLEET",
		audience: "Business, logistics, and operational vehicle visibility",
		priceLabel: "Business band",
		summary: "Scaled around deployment scope",
		supportLabel: "Dashboard visibility and operational oversight",
	},
	{
		eyebrow: "EXECUTIVE",
		audience: "Sensitive vehicles that need security-led installation",
		priceLabel: "Private band",
		summary: "Quoted by vehicle and concealment needs",
		supportLabel: "Enhanced discretion, camera options, and support",
	},
];
const protectionEnhancers = [
	{
		title: "Dashcam evidence layer",
		description: "Pair location visibility with incident footage and stronger driver accountability.",
	},
	{
		title: "Fuel and route reporting",
		description: "Add operational reporting for teams that need more than theft-response tools.",
	},
	{
		title: "Priority support access",
		description: "Move faster when alerts, troubleshooting, or recovery coordination become urgent.",
	},
];
---

{
	Array.isArray(data?.pricing) && data.pricing.length > 0 && (
		<section
			id="pricing"
			aria-labelledby="pricing-heading"
			class="scrolling-section bg-[var(--color-secondary)] py-24 text-white"
		>
			<div class="mx-auto max-w-7xl px-6">
				<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-end">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-accent)]">
							Vehicle Protection Plans
						</p>
						<h2
							id="pricing-heading"
							class="mt-4 text-4xl font-extrabold text-white"
						>
							Protection is matched to the value you are securing, not pushed as one generic tracker.
						</h2>
						<p class="mt-5 max-w-3xl text-base leading-8 text-[color:rgba(255,255,255,0.72)]">
							Each plan is scoped around your vehicle type, response expectations, and how much visibility you need after installation day.
						</p>
					</div>
					<div class="rounded-[2rem] border border-[color:rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.03))] p-6">
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:rgba(255,255,255,0.56)]">
							How We Scope It
						</p>
						<div class="mt-4 grid gap-3 text-sm text-[color:rgba(255,255,255,0.8)]">
							<div class="rounded-2xl border border-[color:rgba(255,255,255,0.06)] bg-[color:rgba(255,255,255,0.04)] px-4 py-3">
								Vehicle value and exposure
							</div>
							<div class="rounded-2xl border border-[color:rgba(255,255,255,0.06)] bg-[color:rgba(255,255,255,0.04)] px-4 py-3">
								Tracking depth and reporting needs
							</div>
							<div class="rounded-2xl border border-[color:rgba(181,18,27,0.34)] bg-[color:rgba(181,18,27,0.16)] px-4 py-3 text-white">
								Remote response and support level
							</div>
						</div>
					</div>
				</div>

				<div class="mt-14 grid gap-6 xl:grid-cols-4" role="list">
					{data.pricing.map((plan, idx) => {
						const isFeatured = idx === featuredPlanIndex;
						const meta = planMeta[idx] ?? {
							eyebrow: `PLAN 0${idx + 1}`,
							audience: "Protection matched to your vehicle and operating context",
							priceLabel: "Protection band",
							summary: "Quoted after review",
							supportLabel: "Quote-based support level",
						};
						return (
						<article
							role="listitem"
							class={`card flex h-full flex-col rounded-[2rem] p-7 text-white transition hover:-translate-y-1 ${
								isFeatured
									? "border border-[color:rgba(181,18,27,0.65)] bg-[linear-gradient(180deg,rgba(181,18,27,0.22),rgba(255,255,255,0.05))] shadow-[0_24px_70px_rgba(181,18,27,0.18)]"
									: "border border-[color:rgba(255,255,255,0.10)] bg-[color:rgba(255,255,255,0.04)]"
							}`}
							style={{
								animationDelay: `${idx * 100}ms`,
								animationFillMode: "both",
							}}
							aria-label={`Pricing plan: ${plan.plan}`}
						>
							<header>
								<p class={`text-xs font-semibold uppercase tracking-[0.2em] ${isFeatured ? "text-[var(--color-accent)]" : "text-[color:rgba(255,255,255,0.56)]"}`}>
									{isFeatured ? "RECOMMENDED" : meta.eyebrow}
								</p>
								<h3 class="mt-4 text-2xl font-bold text-white">
									{plan.plan}
								</h3>
								<p class="mt-4 text-sm leading-7 text-[color:rgba(255,255,255,0.7)]">
									{meta.audience}
								</p>
							</header>

							<div class={`mt-6 rounded-[1.5rem] border p-5 ${isFeatured ? "border-[color:rgba(181,18,27,0.5)] bg-[color:rgba(181,18,27,0.16)]" : "border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)]"}`}>
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:rgba(255,255,255,0.56)]">
									{meta.priceLabel}
								</p>
								<p class="mt-3 text-2xl font-bold text-white">
									{plan.price || meta.summary}
								</p>
								<p class="mt-2 text-sm text-[color:rgba(255,255,255,0.72)]">
									{meta.supportLabel}
								</p>
							</div>

							<ul class="mt-8 flex-1 space-y-3 text-sm text-[color:rgba(255,255,255,0.82)]">
								{plan.features.map((f) => (
									<li class="flex items-start gap-3">
										<Icon
											name="heroicons-solid:check"
											class={`mt-0.5 h-5 w-5 ${isFeatured ? "text-[var(--color-accent)]" : "text-[var(--color-primary)]"}`}
											aria-hidden="true"
										/>
										<span>{f}</span>
									</li>
								))}
							</ul>
							<a
								href={data.content.heroSection.ctaUrl}
								class={`mt-8 inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold transition ${isFeatured ? "bg-[var(--color-primary)] text-white shadow-[0_18px_40px_rgba(181,18,27,0.26)] hover:bg-[var(--color-hover)]" : "border border-[color:rgba(255,255,255,0.12)] text-white hover:border-[color:var(--color-accent)] hover:text-[var(--color-accent)]"}`}
							>
								Request This Plan
							</a>
						</article>
					)})}
				</div>

				<div class="mt-12 rounded-[2rem] border border-[color:rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(255,255,255,0.05),rgba(255,255,255,0.03))] p-8">
					<p class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--color-accent)]">
						Protection Enhancers
					</p>
					<div class="mt-6 grid gap-4 md:grid-cols-3">
						{protectionEnhancers.map((item) => (
							<div class="rounded-[1.5rem] border border-[color:rgba(255,255,255,0.08)] bg-[color:rgba(255,255,255,0.04)] px-5 py-5">
								<h3 class="text-lg font-semibold text-white">{item.title}</h3>
								<p class="mt-3 text-sm leading-7 text-[color:rgba(255,255,255,0.72)]">
									{item.description}
								</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>
	)
}
