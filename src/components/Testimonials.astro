---
import { Icon } from "astro-icon/components";
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
const testimonialsSection = data.content?.testimonialsSection;
---

{Array.isArray(testimonialsSection?.testimonials) && testimonialsSection?.testimonials?.length > 0 && <section
	id="testimonials"
	aria-labelledby="testimonials-heading"
	role="region"
	class="scrolling-section bg-[var(--color-background)] py-24"
>
	<div class="mx-auto max-w-7xl px-6">
		{testimonialsSection?.heading && <div class="mx-auto max-w-3xl text-center">
			<p class="text-sm font-semibold uppercase tracking-[0.28em] text-[var(--color-primary)]">
				Client Confidence
			</p>
			<h2
				id="testimonials-heading"
				class="mt-4 text-3xl font-bold text-[var(--color-heading)] md:text-4xl"
			>
				{testimonialsSection.heading}
			</h2>
		</div> }
	

		<div class="mt-14 grid gap-6 lg:grid-cols-2">
			{Array.isArray(testimonialsSection?.testimonials) && testimonialsSection?.testimonials?.length > 0 &&
				testimonialsSection?.testimonials.map((t, index) => (
					<figure
						class="card rounded-[2rem] border p-7 transition-transform duration-500 ease-in-out opacity-0 animate-fade-in-up"
						style={`animation-delay: ${index * 150}ms; border-color: var(--border-soft); background: var(--card-bg-elevated); box-shadow: var(--shadow-soft);`}
					>
						<div class="mb-4 flex gap-1">
							{[...Array(t.rating)].map(() => (
								<Icon
									name="heroicons-solid:star"
									class="h-5 w-5 text-[var(--color-primary)]"
									aria-hidden="true"
								/>
							))}
						</div>

						<blockquote class="mb-6 text-lg leading-8 text-[var(--color-heading)]">
							<p>“{t.comment}”</p>
						</blockquote>

						<figcaption class="flex items-center gap-4">
							<div class="flex h-12 w-12 items-center justify-center rounded-full text-sm font-bold text-[var(--color-primary)]" style="background: var(--surface-3);">
								{t.name.split(" ").map((part) => part[0]).join("").slice(0, 2)}
							</div>
							<div>
								<p class="text-sm font-semibold text-[var(--color-heading)]">
									{t.name}
								</p>
								<p class="text-sm" style="color: var(--text-soft);">{t.position}</p>
							</div>
						</figcaption>
					</figure>
				))}
		</div>
	</div>
</section>
}


<style>
	@keyframes fade-in-up {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in-up {
		animation: fade-in-up 0.6s forwards;
	}
</style>
