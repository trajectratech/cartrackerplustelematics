---
import type { ThemeConfig } from "../types/theme";

export interface Props {
	data: ThemeConfig;
}

const { data } = Astro.props;
---

{
	data?.map?.embedUrl && (
		<section class="bg-white px-6 pb-16 pt-0" aria-labelledby="map-heading">
			<div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] border border-[color:rgba(8,17,31,0.08)] bg-[var(--color-background)] shadow-[0_24px_60px_rgba(8,17,31,0.08)]">
				<div class="border-b border-[color:rgba(8,17,31,0.08)] px-6 py-5">
					<h2 id="map-heading" class="text-2xl font-bold text-[var(--color-heading)]">
						Visit us or schedule an on-site installation
					</h2>
					<p class="mt-2 text-sm text-[var(--color-muted)]">
						{data.contact.address}
					</p>
				</div>
				{data?.map?.embedUrl && (
					<iframe
						src={data.map.embedUrl}
						width="100%"
						height="360"
						class="border-0"
						loading="lazy"
						allowfullscreen
						title="Embedded map"
						referrerpolicy="no-referrer-when-downgrade"
					/>
				)}
			</div>
		</section>
	)
}
